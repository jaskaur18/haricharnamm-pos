{
  "expo": {
    "name": "HARI CHARNAMM POS",
    "slug": "hari-charnamm-pos",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/app_logo.png",
    "scheme": "haricharnammpos",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.honeysingh.haricharnammpos",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app_logo.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.honeysingh.haricharnammpos",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/app_logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HARI CHARNAMM POS to access your photos to attach product images.",
          "cameraPermission": "Allow HARI CHARNAMM POS to use the camera to capture product images.",
          "microphonePermission": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HARI CHARNAMM POS to scan product barcodes."
        }
      ],
      "expo-web-browser",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c04a4b3-b3b0-4ce6-9a94-481b3c3c2bc7"
      }
    }
  }
}
